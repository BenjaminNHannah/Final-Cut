<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/moviePosterImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="16dp"
            android:background="#DDDDDD"
            android:scaleType="centerInside"
            android:contentDescription="Movie Poster Placeholder" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Final-Cut"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Find your perfect movie match"
            android:textSize="14sp"
            android:textColor="#777777"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Preferred Genre:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/genreRadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/radioAction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Action / Adventure"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/radioComedy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Comedy"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/radioSciFi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sci-Fi / Fantasy"
                android:textSize="16sp"
                android:checked="true" />
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your Streaming Services:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <CheckBox
            android:id="@+id/checkNetflix"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Netflix"
            android:textSize="16sp"
            android:checked="true" />

        <CheckBox
            android:id="@+id/checkHulu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hulu"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/checkPrime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prime Video"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnGenerateMovie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Generate Movie Recommendation"
            android:textSize="16sp"
            android:padding="12dp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Streaming Preview Panel:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <WebView
            android:id="@+id/directoryWebView"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="#EEEEEE" />

    </LinearLayout>
</ScrollView>