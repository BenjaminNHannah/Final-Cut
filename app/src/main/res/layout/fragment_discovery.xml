<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/moviePosterImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="16dp"
            android:background="#DDDDDD"
            android:scaleType="centerInside"
            android:contentDescription="@string/movie_poster_description" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#333333" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/discovery_subtitle"
            android:textSize="14sp"
            android:textColor="#777777"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_genre"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/genreRadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <RadioButton
                android:id="@+id/radioAction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/genre_action"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/radioComedy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/genre_comedy"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/radioSciFi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/genre_scifi"
                android:textSize="16sp"
                android:checked="true" />
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/streaming_services"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <CheckBox
            android:id="@+id/checkNetflix"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/service_netflix"
            android:textSize="16sp"
            android:checked="true" />

        <CheckBox
            android:id="@+id/checkHulu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/service_hulu"
            android:textSize="16sp" />

        <CheckBox
            android:id="@+id/checkPrime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/service_prime"
            android:textSize="16sp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnGenerateMovie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_generate"
            android:textSize="16sp"
            android:padding="12dp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/share_title"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnShareText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_share_text"
            android:textSize="16sp"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnShareEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_share_email"
            android:textSize="16sp"
            android:padding="12dp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/preview_panel"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <WebView
            android:id="@+id/directoryWebView"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="#EEEEEE" />

    </LinearLayout>
</ScrollView>