<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/fc_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Final-Cut"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/fc_text_primary"
            android:letterSpacing="0.05"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/fc_card"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/moviePosterImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:background="@color/fc_element"
                android:scaleType="fitCenter"
                android:contentDescription="Movie Poster"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/movieTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AWAITING SELECTION"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/fc_text_primary" />

            <TextView
                android:id="@+id/movieOverview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap GENERATE to receive a recommendation."
                android:textSize="13sp"
                android:textColor="@color/fc_text_secondary"
                android:layout_marginTop="6dp"
                android:lineSpacingMultiplier="1.4" />

            <TextView
                android:id="@+id/movieStreamingInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/fc_red"
                android:layout_marginTop="10dp"
                android:letterSpacing="0.05" />

        </LinearLayout>

        <TextView
            android:id="@+id/btnGenerateMovie"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="GENERATE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@color/fc_red"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/fc_card"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GENRE"
                android:textSize="10sp"
                android:textColor="@color/fc_text_muted"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/genreSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/fc_element"
                android:backgroundTint="@color/fc_text_secondary"
                android:popupBackground="@color/fc_card"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/fc_card"
            android:padding="14dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STREAMING SERVICES"
                android:textSize="10sp"
                android:textColor="@color/fc_text_muted"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/serviceChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipNetflix"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Netflix"
                    android:textSize="12sp"
                    android:checkable="true"
                    android:checked="true"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    app:checkedIconVisible="false"
                    app:chipStrokeWidth="0dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPrime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Prime Video"
                    android:textSize="12sp"
                    android:checkable="true"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    app:checkedIconVisible="false"
                    app:chipStrokeWidth="0dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDisney"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Disney+"
                    android:textSize="12sp"
                    android:checkable="true"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    app:checkedIconVisible="false"
                    app:chipStrokeWidth="0dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHulu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hulu"
                    android:textSize="12sp"
                    android:checkable="true"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    app:checkedIconVisible="false"
                    app:chipStrokeWidth="0dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipMax"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Max"
                    android:textSize="12sp"
                    android:checkable="true"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    app:checkedIconVisible="false"
                    app:chipStrokeWidth="0dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipApple"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Apple TV+"
                    android:textSize="12sp"
                    android:checkable="true"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    app:checkedIconVisible="false"
                    app:chipStrokeWidth="0dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipParamount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paramount+"
                    android:textSize="12sp"
                    android:checkable="true"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    app:checkedIconVisible="false"
                    app:chipStrokeWidth="0dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPeacock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Peacock"
                    android:textSize="12sp"
                    android:checkable="true"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    app:checkedIconVisible="false"
                    app:chipStrokeWidth="0dp" />

            </com.google.android.material.chip.ChipGroup>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/fc_card"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SHARE MOVIE NIGHT"
                android:textSize="10sp"
                android:textColor="@color/fc_text_muted"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnShareText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TEXT"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/fc_text_primary"
                    android:background="@color/fc_element"
                    android:gravity="center"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/btnShareEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="EMAIL"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/fc_text_primary"
                    android:background="@color/fc_element"
                    android:gravity="center"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>